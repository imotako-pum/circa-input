{
  "name": "@circa-input/core",
  "version": "0.1.0",
  "description": "Core logic for circa-input — value + ambiguity input primitive",
  "license": "MIT",
  "author": "imotako-pum",
  "homepage": "https://github.com/imotako-pum/circa-input/tree/main/packages/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/imotako-pum/circa-input.git",
    "directory": "packages/core"
  },
  "keywords": [
    "circa-input",
    "ambiguity",
    "fuzzy-input",
    "range-input",
    "uncertainty",
    "ui-primitive"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vite-plugin-dts": "^4.5.0"
  }
}
