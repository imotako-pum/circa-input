{
  "name": "@circa-input/react",
  "version": "0.2.0",
  "description": "React adapter for circa-input — use <CircaInput> in React apps",
  "license": "MIT",
  "author": "imotako-pum",
  "homepage": "https://github.com/imotako-pum/circa-input/tree/main/packages/react",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imotako-pum/circa-input.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/imotako-pum/circa-input/issues"
  },
  "keywords": [
    "circa-input",
    "circa",
    "approximate-input",
    "fuzzy-input",
    "react",
    "slider",
    "tolerance",
    "ambiguity",
    "uncertainty",
    "uncertainty-ui",
    "plus-minus",
    "value-tolerance",
    "range-input",
    "react-component",
    "form-input",
    "ui-primitive"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@circa-input/core": "workspace:*",
    "@circa-input/web-component": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^17.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  }
}
