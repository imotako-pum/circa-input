{
  "name": "@circa-input/web-component",
  "version": "0.1.0",
  "description": "Web Component implementation of circa-input (<circa-input> tag)",
  "license": "MIT",
  "author": "imotako-pum",
  "homepage": "https://github.com/imotako-pum/circa-input/tree/main/packages/web-component",
  "repository": {
    "type": "git",
    "url": "https://github.com/imotako-pum/circa-input.git",
    "directory": "packages/web-component"
  },
  "bugs": {
    "url": "https://github.com/imotako-pum/circa-input/issues"
  },
  "keywords": [
    "circa-input",
    "slider",
    "web-component",
    "custom-element",
    "tolerance",
    "ambiguity",
    "uncertainty",
    "plus-minus",
    "range-input",
    "form-component",
    "ui-primitive"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.iife.js",
  "jsdelivr": "./dist/index.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.config.iife.ts",
    "test": "vitest run",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@circa-input/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.8.3",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  }
}
